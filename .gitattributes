# 强制所有文本文件使用 LF 换行（跨平台一致性）
* text=auto eol=lf

# 源码显式声明
*.cpp   text eol=lf
*.hpp   text eol=lf
*.h     text eol=lf
*.c     text eol=lf
*.txt   text eol=lf
*.cmake text eol=lf
*.md    text eol=lf

# Windows 脚本保留 CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# 二进制
*.png   binary
*.jpg   binary
*.ico   binary
*.pdf   binary
